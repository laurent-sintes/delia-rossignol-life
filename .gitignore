__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
.test-tmp/
.tools/
.runtime/
_site/
dist/
build/
*.egg-info/

.env
.env.*
!.env.example
private/
generated/
*.tmp
~$*

# Données de travail privées dans un dépôt public
data/applications/*
!data/applications/.gitkeep
data/offers/*
!data/offers/.gitkeep
data/sources/manifests/*
!data/sources/manifests/.gitkeep
data/review/queue/*
!data/review/queue/example.json

# Exports et originaux susceptibles de contenir des données personnelles
*.pdf
*.docx
*.odt
*.zip
!templates/**/*.docx
!templates/**/*.pdf
