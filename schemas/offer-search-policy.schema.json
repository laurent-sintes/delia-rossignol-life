{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "result_limit", "candidate_pool_minimum", "candidate_pool_maximum", "active_verification_max_age_days", "freshness_days", "contracts", "diversity", "recommendation_bands", "functional_query_families", "profile_family_filters", "location_queries", "regional_source_audit", "source_domains", "priority_sector_coverage", "source_strategy", "weights"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "result_limit": {"type": "integer", "minimum": 1, "maximum": 100},
    "candidate_pool_minimum": {"type": "integer", "minimum": 10},
    "candidate_pool_maximum": {"type": "integer", "minimum": 10, "maximum": 100},
    "active_verification_max_age_days": {"type": "integer", "minimum": 1, "maximum": 30},
    "freshness_days": {"type": "integer", "minimum": 1},
    "contracts": {
      "type": "object",
      "required": ["preferred", "acceptable", "excluded"],
      "properties": {
        "preferred": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "acceptable": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "excluded": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "diversity": {
      "type": "object",
      "required": ["max_per_employer", "max_per_source"],
      "properties": {
        "max_per_employer": {"type": "integer", "minimum": 1},
        "max_per_source": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "recommendation_bands": {
      "type": "object",
      "required": ["priority_minimum_score", "possible_minimum_score"],
      "properties": {
        "priority_minimum_score": {"type": "number", "minimum": 0, "maximum": 100},
        "possible_minimum_score": {"type": "number", "minimum": 0, "maximum": 100}
      },
      "additionalProperties": false
    },
    "location_queries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "regional_source_audit": {"type": "string", "const": "config/offer-source-audit.json"},
    "functional_query_families": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "profile_family_filters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "decision", "strong_title_markers", "family_markers", "technical_markers", "minimum_technical_markers"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 1},
          "decision": {"const": "exclude"},
          "strong_title_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "family_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "technical_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "minimum_technical_markers": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "sector_emphasis": {
      "type": "object",
      "required": ["labels", "multiplier"],
      "properties": {
        "labels": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "multiplier": {"type": "number", "minimum": 1}
      },
      "additionalProperties": false
    },
    "source_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "priority_sector_coverage": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "source_strategy": {
      "type": "object",
      "required": ["priority_order", "direct_employer_domains", "specialized_domains", "require_direct_offer_verification"],
      "properties": {
        "priority_order": {
          "type": "array",
          "const": ["direct_employer", "specialized", "generalist"]
        },
        "direct_employer_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "specialized_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "require_direct_offer_verification": {"type": "boolean", "const": true}
      },
      "additionalProperties": false
    },
    "weights": {
      "type": "object",
      "required": ["contract", "sector", "functional_domain", "knowledge_overlap", "freshness", "constraints"],
      "properties": {
        "contract": {"type": "number", "minimum": 0},
        "sector": {"type": "number", "minimum": 0},
        "functional_domain": {"type": "number", "minimum": 0},
        "knowledge_overlap": {"type": "number", "minimum": 0},
        "freshness": {"type": "number", "minimum": 0},
        "constraints": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
