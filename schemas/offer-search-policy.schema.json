{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "active_verification_max_age_days", "freshness_days", "contracts", "recommendation_bands", "semantic_matching", "functional_query_families", "sector_functional_coverage", "profile_family_filters", "location_queries", "collector", "regional_source_audit", "source_domains", "manual_source_domains", "priority_sector_coverage", "source_strategy", "weights"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "active_verification_max_age_days": {"type": "integer", "minimum": 1, "maximum": 30},
    "freshness_days": {"type": "integer", "minimum": 1},
    "contracts": {
      "type": "object",
      "required": ["preferred", "acceptable", "excluded"],
      "properties": {
        "preferred": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "acceptable": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "excluded": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "recommendation_bands": {
      "type": "object",
      "required": ["priority_minimum_score", "possible_minimum_score"],
      "properties": {
        "priority_minimum_score": {"type": "number", "minimum": 0, "maximum": 100},
        "possible_minimum_score": {"type": "number", "minimum": 0, "maximum": 100}
      },
      "additionalProperties": false
    },
    "semantic_matching": {
      "type": "object",
      "required": ["review_schema_version", "prompt_version", "importance_weights", "match_factors", "transferability_guidance"],
      "properties": {
        "review_schema_version": {"type": "integer", "const": 3},
        "prompt_version": {"type": "string", "minLength": 1},
        "importance_weights": {
          "type": "object",
          "required": ["required", "preferred"],
          "properties": {
            "required": {"type": "number", "exclusiveMinimum": 0},
            "preferred": {"type": "number", "exclusiveMinimum": 0}
          },
          "additionalProperties": false
        },
        "match_factors": {
          "type": "object",
          "required": ["exact", "transferable", "gap", "unknown"],
          "properties": {
            "exact": {"type": "number", "minimum": 0, "maximum": 1},
            "transferable": {"type": "number", "minimum": 0, "maximum": 1},
            "gap": {"type": "number", "const": 0},
            "unknown": {"type": "number", "const": 0}
          },
          "additionalProperties": false
        },
        "transferability_guidance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["target_sector_id", "source_sector_ids", "applicable_query_family_ids", "profile_evidence_ids", "rationale", "non_transferable_activities"],
            "properties": {
              "target_sector_id": {"type": "string", "minLength": 1},
              "source_sector_ids": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              },
              "applicable_query_family_ids": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              },
              "profile_evidence_ids": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              },
              "rationale": {"type": "string", "minLength": 1},
              "non_transferable_activities": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {"type": "string", "minLength": 1}
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "collector": {
      "type": "object",
      "required": ["user_agent", "timeout_seconds", "retries", "delay_seconds", "max_response_bytes", "max_concurrent_sources", "location_markers", "adapter_domains"],
      "properties": {
        "user_agent": {"type": "string", "minLength": 1},
        "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 120},
        "retries": {"type": "integer", "minimum": 0, "maximum": 5},
        "delay_seconds": {"type": "number", "minimum": 0, "maximum": 10},
        "max_response_bytes": {"type": "integer", "minimum": 1024, "maximum": 52428800},
        "max_concurrent_sources": {"type": "integer", "minimum": 1, "maximum": 12},
        "location_markers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "adapter_domains": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      },
      "additionalProperties": false
    },
    "location_queries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "regional_source_audit": {"type": "string", "const": "config/offer-source-audit.json"},
    "functional_query_families": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "sector_functional_coverage": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "profile_family_filters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "decision", "strong_title_markers", "family_markers", "technical_markers", "minimum_technical_markers"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 1},
          "decision": {"const": "exclude"},
          "strong_title_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "family_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "technical_markers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "minimum_technical_markers": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    },
    "source_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "manual_source_domains": {
      "type": "object",
      "required": ["core", "complementary"],
      "properties": {
        "core": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "complementary": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "priority_sector_coverage": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "source_strategy": {
      "type": "object",
      "required": ["priority_order", "direct_employer_domains", "specialized_domains", "warn_on_missing_employer_page"],
      "properties": {
        "priority_order": {
          "type": "array",
          "const": ["direct_employer", "specialized", "generalist"]
        },
        "direct_employer_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "specialized_domains": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "warn_on_missing_employer_page": {"type": "boolean", "const": true}
      },
      "additionalProperties": false
    },
    "weights": {
      "type": "object",
      "required": ["contract", "sector", "functional_domain", "semantic_match", "freshness", "constraints"],
      "properties": {
        "contract": {"type": "number", "minimum": 0},
        "sector": {"type": "number", "minimum": 0},
        "functional_domain": {"type": "number", "minimum": 0},
        "semantic_match": {"type": "number", "minimum": 0},
        "freshness": {"type": "number", "minimum": 0},
        "constraints": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
