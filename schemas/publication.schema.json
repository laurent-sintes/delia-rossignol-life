{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["site", "pages"],
  "additionalProperties": false,
  "properties": {
    "site": {
      "type": "object",
      "required": ["title", "description"],
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "title", "kind"],
        "properties": {
          "slug": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "title": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["markdown", "administration", "json", "collection", "knowledge", "mental-model"]},
          "source": {"type": "string", "minLength": 1},
          "source_glob": {"type": "string", "minLength": 1},
          "fields": {"type": "array"},
          "sections": {"type": "array"}
        }
      }
    }
  }
}
