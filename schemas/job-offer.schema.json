{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id", "title", "employer", "source_url", "source_site", "published_at", "captured_at",
    "last_verified_at", "summary", "location_label", "contract_type", "full_time",
    "required_skills", "preferred_skills", "conditions"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "employer": {"type": "string", "minLength": 1},
    "source_url": {"type": "string", "format": "uri", "minLength": 1},
    "source_site": {"type": "string", "minLength": 1},
    "source_kind": {"type": "string", "enum": ["direct_employer", "specialized", "aggregator"]},
    "canonical_offer_id": {"type": "string", "minLength": 1},
    "employer_source_url": {"type": "string", "format": "uri", "minLength": 1},
    "verification_status": {"type": "string", "enum": ["active", "closed", "expired", "pending", "unreachable"]},
    "verification_note": {"type": "string", "minLength": 1},
    "source_warning": {"type": "string", "minLength": 1},
    "published_at": {"type": ["string", "null"], "format": "date"},
    "captured_at": {"type": "string", "format": "date-time"},
    "last_verified_at": {"type": "string", "format": "date-time"},
    "summary": {"type": "string", "minLength": 1},
    "location_label": {"type": "string", "minLength": 1},
    "industry_sector_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "job_role_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "location_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "contract_type": {"type": "string", "minLength": 1},
    "full_time": {"type": ["boolean", "null"]},
    "sector_labels": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "functional_domains": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "work_mode": {"type": "string", "enum": ["onsite", "hybrid", "remote", "mobile", "unknown"]},
    "schedule": {"type": "object"},
    "compensation": {
      "type": "object",
      "properties": {
        "minimum": {"type": "number"},
        "maximum": {"type": "number"},
        "currency": {"type": "string", "minLength": 3},
        "period": {"type": "string", "enum": ["hour", "month", "year"]}
      }
    },
    "required_skills": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "preferred_skills": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "semantic_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "importance", "kind", "offer_evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "description": {"type": "string", "minLength": 1},
          "importance": {"type": "string", "enum": ["required", "preferred"]},
          "kind": {"type": "string", "enum": ["mission", "skill", "experience", "qualification", "condition", "other"]},
          "offer_evidence": {
            "type": "object",
            "required": ["locator", "excerpt"],
            "properties": {
              "locator": {"type": "string", "minLength": 1},
              "excerpt": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "semantic_matches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["requirement_id", "match_type", "llm_confidence", "profile_evidence_refs", "rationale"],
        "properties": {
          "requirement_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "match_type": {"type": "string", "enum": ["exact", "transferable", "gap", "unknown"]},
          "llm_confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "profile_evidence_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "object",
              "required": ["id", "field"],
              "properties": {
                "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9-]*$"},
                "field": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
              },
              "additionalProperties": false
            }
          },
          "rationale": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"match_type": {"enum": ["exact", "transferable"]}}},
            "then": {"properties": {"profile_evidence_refs": {"minItems": 1}}}
          }
        ],
        "additionalProperties": false
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "description", "mandatory", "profile_status", "profile_evidence_ids", "assessment_note", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "kind": {
            "type": "string",
            "enum": ["minimum_experience", "prior_role", "sector_experience", "qualification", "certification", "language", "other"]
          },
          "description": {"type": "string", "minLength": 1},
          "mandatory": {"type": "boolean"},
          "minimum_years": {"type": "number", "minimum": 0},
          "credential_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "industry_sector_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "profile_status": {"type": "string", "enum": ["met", "not_demonstrated", "unmet", "unknown"]},
          "profile_evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "assessment_note": {"type": "string", "minLength": 1},
          "evidence": {
            "type": "object",
            "required": ["locator", "excerpt"],
            "properties": {
              "locator": {"type": "string", "minLength": 1},
              "excerpt": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "certification"}}},
            "then": {"required": ["credential_id"]}
          }
        ],
        "additionalProperties": false
      }
    },
    "conditions": {"type": "object"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "locator", "excerpt"],
        "properties": {
          "field": {"type": "string", "minLength": 1},
          "locator": {"type": "string", "minLength": 1},
          "excerpt": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "extraction": {
      "type": "object",
      "required": ["method", "extractor_version", "review_status", "ambiguous_fields"],
      "properties": {
        "method": {"type": "string", "enum": ["deterministic-json-ld", "deterministic-html", "deterministic-api"]},
        "extractor_version": {"type": "integer", "minimum": 1},
        "review_status": {"type": "string", "enum": ["required", "completed"]},
        "ambiguous_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "source_archive_path": {"type": "string", "minLength": 1},
        "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "review_method": {"type": "string", "minLength": 1},
        "review_model": {"type": "string", "minLength": 1},
        "review_prompt_version": {"type": "string", "minLength": 1},
        "review_profile_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "review_schema_version": {"type": "integer", "minimum": 1},
        "semantic_cache_key": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "semantic_cache_reused_at": {"type": "string", "format": "date-time"}
      },
      "allOf": [
        {
          "if": {"properties": {"review_status": {"const": "completed"}}},
          "then": {"required": ["reviewed_at", "review_method"]}
        },
        {
          "if": {"properties": {"review_schema_version": {"const": 3}}, "required": ["review_schema_version"]},
          "then": {"required": ["review_model", "review_prompt_version", "review_profile_sha256"]}
        }
      ],
      "additionalProperties": false
    }
  }
}
