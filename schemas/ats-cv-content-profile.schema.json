{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id", "status", "template_id", "person_id", "email_contact_id", "phone_contact_id",
    "target_title", "profile_summary", "skill_ids", "experiences", "education", "language_id"
  ],
  "additionalProperties": false,
  "$defs": {
    "entityField": {
      "type": "object",
      "required": ["entity_type", "entity_id", "field"],
      "additionalProperties": false,
      "properties": {
        "entity_type": {"type": "string", "minLength": 1},
        "entity_id": {"type": "string", "minLength": 1},
        "field": {"type": "string", "minLength": 1}
      }
    }
  },
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["validated"]},
    "template_id": {"type": "string", "const": "ats-classic"},
    "person_id": {"type": "string", "minLength": 1},
    "email_contact_id": {"type": "string", "minLength": 1},
    "phone_contact_id": {"type": "string", "minLength": 1},
    "target_title": {"type": "string", "minLength": 1},
    "profile_summary": {"type": "string", "minLength": 1},
    "skill_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "experiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entity_id", "heading", "heading_evidence", "bullets"],
        "additionalProperties": false,
        "properties": {
          "entity_id": {"type": "string", "minLength": 1},
          "heading": {"type": "string", "minLength": 1},
          "heading_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/entityField"}
          },
          "bullets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["text", "evidence"],
              "additionalProperties": false,
              "properties": {
                "text": {"type": "string", "minLength": 1},
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"$ref": "#/$defs/entityField"}
                }
              }
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entity_type", "entity_id"],
        "additionalProperties": false,
        "properties": {
          "entity_type": {"type": "string", "enum": ["credential", "education"]},
          "entity_id": {"type": "string", "minLength": 1}
        }
      }
    },
    "language_id": {"type": "string", "minLength": 1}
  }
}
