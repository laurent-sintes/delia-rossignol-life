{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "updated_at", "skills"],
  "additionalProperties": false,
  "$defs": {
    "entityField": {
      "type": "object",
      "required": ["entity_type", "entity_id", "field"],
      "additionalProperties": false,
      "properties": {
        "entity_type": {"type": "string", "minLength": 1},
        "entity_id": {"type": "string", "minLength": 1},
        "field": {"type": "string", "minLength": 1}
      }
    },
    "skill": {
      "type": "object",
      "required": ["id", "name", "category", "level", "transferable", "summary", "keywords", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "category": {
          "type": "string",
          "enum": ["administration", "client", "commerce", "projet", "fournisseurs", "pilotage", "digital", "management", "langue"]
        },
        "level": {"type": "string", "enum": ["demontree", "expert"]},
        "transferable": {"type": "boolean"},
        "summary": {"type": "string", "minLength": 1},
        "keywords": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/entityField"}
        }
      }
    }
  },
  "properties": {
    "status": {"type": "string", "enum": ["validated"]},
    "updated_at": {"type": "string", "format": "date"},
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/skill"}
    }
  }
}
