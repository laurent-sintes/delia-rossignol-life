{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "audited_at", "scope", "sources", "not_added"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "audited_at": {"type": "string", "format": "date"},
    "scope": {
      "type": "object",
      "required": ["area", "method", "functional_domains"],
      "properties": {
        "area": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "functional_domains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["organization", "organization_type", "career_url", "scan_domain", "scan_priority", "sectors", "functional_domains", "evidence_urls", "rationale"],
        "properties": {
          "organization": {"type": "string", "minLength": 1},
          "organization_type": {
            "enum": ["private_employer", "public_employer", "private_specialized_portal", "public_specialized_portal"]
          },
          "career_url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "scan_domain": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9.-]+$"},
          "scan_priority": {"enum": ["core", "complementary"]},
          "automated_collection": {"type": "boolean"},
          "sectors": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "functional_domains": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "evidence_urls": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "format": "uri", "pattern": "^https://"}
          },
          "rationale": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "not_added": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["organization", "reference_url", "reason"],
        "properties": {
          "organization": {"type": "string", "minLength": 1},
          "reference_url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "reason": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
